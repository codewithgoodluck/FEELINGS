rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Pins, conversations, messages, reports — any signed-in user
    match /pins/{pin} {
      allow read, write: if request.auth != null;
    }
    match /conversations/{conv} {
      allow read, write: if request.auth != null;
    }
    match /conversations/{conv}/messages/{msg} {
      allow read, write: if request.auth != null;
    }
    match /reports/{report} {
      allow read, write: if request.auth != null;
    }
    match /messageReports/{report} {
      allow create: if request.auth != null;
    }

    // Presence — keyed by stable device ID (localStorage UUID).
    // Ownership is enforced via the uid field stored in the document.
    match /presence/{deviceId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    // Stats — read by anyone signed-in; writes used for totalUsers counter
    match /stats/{stat} {
      allow read, write: if request.auth != null;
    }

  }
}
