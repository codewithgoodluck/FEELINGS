rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Pins — belt-and-suspenders country guard on create
    match /pins/{pin} {
      allow read, update, delete: if request.auth != null;
      allow create: if request.auth != null
        && (
          !('country' in request.resource.data)
          || request.resource.data.country == null
          || !exists(/databases/$(database)/documents/userCountry/$(request.auth.uid))
          || request.resource.data.country ==
             get(/databases/$(database)/documents/userCountry/$(request.auth.uid)).data.country
        );
    }

    // Country claims — keyed by auth uid, written by initPresence
    match /userCountry/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /conversations/{conv} {
      allow read, write: if request.auth != null;
    }
    match /conversations/{conv}/messages/{msg} {
      allow read, write: if request.auth != null;
    }
    match /reports/{report} {
      allow read, write: if request.auth != null;
    }
    match /messageReports/{report} {
      allow create: if request.auth != null;
    }

    // Presence — keyed by stable device ID (localStorage UUID).
    // Ownership is enforced via the uid field stored in the document.
    match /presence/{deviceId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    // Stats — read by anyone signed-in; writes used for totalUsers counter
    match /stats/{stat} {
      allow read, write: if request.auth != null;
    }

  }
}
