rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Pins, conversations, messages, reports — any signed-in user
    match /pins/{pin} {
      allow read, write: if request.auth != null;
    }
    match /conversations/{conv} {
      allow read, write: if request.auth != null;
    }
    match /conversations/{conv}/messages/{msg} {
      allow read, write: if request.auth != null;
    }
    match /reports/{report} {
      allow read, write: if request.auth != null;
    }

    // Presence — anyone can read; users may only write their own doc
    match /presence/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Stats — read by anyone signed-in; writes used for totalUsers counter
    match /stats/{stat} {
      allow read, write: if request.auth != null;
    }

  }
}
